---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Sistema de gestión agronómica de bajo coste: agricultura de precisión rigurosa y accesible para la pequeña y mediana explotación. Código abierto.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const navLinkClass = (href: string) =>
  pathname === href || pathname === `${href}index.html` ? 'active' : '';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <a href={`${base}`} class="nav-brand">MindFarm</a>
      <ul class="nav-links">
        <li><a href={`${base}mindfarm/`} class={navLinkClass(`${base}mindfarm/`)}>El sistema</a></li>
        <li><a href="https://mindfarm-demo.streamlit.app" target="_blank" rel="noreferrer">Herramienta</a></li>
        <li><a href={`${base}contacto/`} class={navLinkClass(`${base}contacto/`)}>Contacto</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <p>
        MindFarm · Agricultura de precisión de bajo coste · Código abierto
      </p>
      <p class="mt-1">
        <a href="mailto:javilosada7@gmail.com">javilosada7@gmail.com</a>
      </p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
